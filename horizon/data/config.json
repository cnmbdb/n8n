    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript"
      ],
      "keywords": [],
      "min_stars": 10,
      "max_items": 40
    }
  },
  "filtering": {
    "ai_score_threshold": 3.5,
    "time_window_hours": 48
  },
  "webhook": {
    "enabled": false
  }
}
