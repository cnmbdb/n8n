        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ggerganov",
        "repo": "llama.cpp",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "autogen",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langgenius",
        "repo": "dify",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "modelcontextprotocol",
