{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 2
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "DeepMind Blog",
        "url": "https://deepmind.google/blog/rss.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Meta AI Blog",
        "url": "https://ai.meta.com/blog/rss/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Microsoft AI Blog",
        "url": "https://blogs.microsoft.com/ai/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "The Batch (Andrew Ng)",
        "url": "https://www.deeplearning.ai/the-batch/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Towards Data Science",
        "url": "https://towardsdatascience.com/feed",
        "enabled": true,
        "category": "ai-ml"
      },
      {
        "name": "Papers With Code",
        "url": "https://paperswithcode.com/latest.rss",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "MIT Technology Review AI",
        "url": "https://www.technologyreview.com/topic/artificial-intelligence/feed",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "The Verge AI",
        "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Ars Technica AI",
        "url": "https://feeds.arstechnica.com/arstechnica/technology-lab",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "VentureBeat AI",
        "url": "https://venturebeat.com/category/ai/feed/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "AI News (artificialintelligence-news.com)",
        "url": "https://www.artificialintelligence-news.com/feed/",
        "enabled": true,
        "category": "ai-news"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 50
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "singularity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "ChatGPT",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "StableDiffusion",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        },
        {
          "subreddit": "langchain",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "fetch_comments": 5
    },
    "github": [
      {
        "type": "user_events",
        "username": "openai",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "anthropics",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "google-deepmind",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "meta-llama",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "huggingface",
        "repo": "transformers",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ggerganov",
        "repo": "llama.cpp",
        "enabled": true
      }
    ]
  },
  "filtering": {
    "ai_score_threshold": 4.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false
  }
}
